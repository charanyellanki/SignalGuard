# Copy to .env and edit as needed. Defaults are in docker-compose.yml.

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=signalguard
POSTGRES_PASSWORD=signalguard
POSTGRES_DB=signalguard
POSTGRES_PORT=5432

# ─── API (unified: REST + ML + optional in-process simulator) ──────────────
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
# Embedded simulator (same process as API when using docker-compose api service)
SIMULATOR_ENABLED=true
DEVICE_COUNT=50
EMIT_INTERVAL_SEC=5
ANOMALY_PROBABILITY=0.02
ENABLE_ISOLATION_FOREST=true
ENABLE_LSTM_AUTOENCODER=true
# Local dev: bootstrap small synthetic models if no W&B / no files in volume
ALLOW_BOOTSTRAP_TRAIN=true
REQUIRE_WANDB_MODEL=false
MODEL_DIR=/app/models/trained
# Optional — production / CI retrain (see README)
# WANDB_API_KEY=
# WANDB_PROJECT=signalguard
# WANDB_ENTITY=

# ─── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
