# Copy to .env and edit as needed. All values have working defaults in docker-compose.yml.

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=signalguard
POSTGRES_PASSWORD=signalguard
POSTGRES_DB=signalguard
POSTGRES_PORT=5432

# ─── Kafka ─────────────────────────────────────────────────────────────────
# KAFKA_HOST_PORT is only for host-machine clients; services inside the
# compose network talk to kafka:9092 directly.
KAFKA_HOST_PORT=29092
KAFKA_TOPIC=device-telemetry
KAFKA_GROUP_ID=detection-service

# ─── Device simulator ──────────────────────────────────────────────────────
DEVICE_COUNT=500
EMIT_INTERVAL_SEC=5
# Probability that any given message is replaced with an anomaly.
ANOMALY_PROBABILITY=0.02

# ─── Detection service ─────────────────────────────────────────────────────
# Toggle either model off to A/B their behavior.
ENABLE_ISOLATION_FOREST=true
ENABLE_LSTM_AUTOENCODER=true

# ─── API ───────────────────────────────────────────────────────────────────
API_PORT=8000
# Comma-separated list of origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173

# ─── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ─── Logging ───────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
