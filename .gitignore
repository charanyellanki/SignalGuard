# ─── Secrets / local config ────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.python-version

# ─── Trained models (Docker volume is api_models) ──────────────────────────
backend/api/models/trained/
backend/archive/**/models/trained/

# ─── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.out.ipynb

# ─── Node / frontend ───────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local
frontend/.turbo/
frontend/coverage/

# ─── Alembic ───────────────────────────────────────────────────────────────
