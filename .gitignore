api/alembic/versions/__pycache__/
backend/api/alembic/versions/__pycache__/
wandb/

# ─── Editor / OS ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ─── Docker / local runtime ────────────────────────────────────────────────
*.pid
*.log
logs/

.claude
